## Pupilla dinamica: arte e misura

```{r}
#| fig-width: 13
#| fig-height: 6

library(shiny)
library(plotly)

# Funzione per generare pupilla dinamica
generate_pupil <- function(pupil_size = 0.9, light_level = 0.5, attention = 0.5) {
  
  # IRIDE (fissa)
  n_iris <- 1200
  theta_iris <- runif(n_iris, 0, 2*pi)
  r_iris <- sqrt(runif(n_iris, 0.5, 1))  # anello esterno
  iris <- tibble(
    x = 2.2 * r_iris * cos(theta_iris),
    y = 2.2 * r_iris * sin(theta_iris),
    zone = "iride"
  )
  
  # PUPILLA (varia in base a parametri)
  # Dimensione base influenzata da luce e attenzione
  base_size <- pupil_size * (1 - light_level * 0.6) * (1 + attention * 0.4)
  
  n_pupil <- 800
  theta_pup <- runif(n_pupil, 0, 2*pi)
  r_pup <- sqrt(runif(n_pupil, 0, 1))
  pupil <- tibble(
    x = base_size * r_pup * cos(theta_pup),
    y = base_size * r_pup * sin(theta_pup),
    zone = "pupilla"
  )
  
  # PALPEBRA
  eyelid <- tibble(
    x = seq(-3.2, 3.2, length.out = 200),
    y_top = 0.42 * sqrt(pmax(0, 10 - x^2)),
    y_bottom = -0.42 * sqrt(pmax(0, 10 - x^2))
  )
  
  list(iris = iris, pupil = pupil, eyelid = eyelid, size = base_size)
}

# Stati predefiniti
states <- list(
  "Luce intensa" = list(light = 0.9, attention = 0.5, pupil = 0.6),
  "Buio" = list(light = 0.1, attention = 0.5, pupil = 1.0),
  "Alta attenzione" = list(light = 0.5, attention = 0.9, pupil = 0.9),
  "Rilassato" = list(light = 0.5, attention = 0.2, pupil = 0.7),
  "Carico cognitivo" = list(light = 0.5, attention = 1.0, pupil = 1.1),
  "Sorpresa" = list(light = 0.4, attention = 0.95, pupil = 1.15)
)

# Genera pupille per tutti gli stati
all_pupils <- map_dfr(names(states), function(state_name) {
  params <- states[[state_name]]
  pup_data <- generate_pupil(params$pupil, params$light, params$attention)
  
  bind_rows(
    pup_data$iris |> mutate(state = state_name),
    pup_data$pupil |> mutate(state = state_name)
  ) |>
    mutate(
      pupil_diameter = round(pup_data$size * 3, 2),
      light_pct = round(params$light * 100),
      attention_pct = round(params$attention * 100)
    )
})

# Palpebra (uguale per tutti)
eyelid_data <- tibble(
  x = seq(-3.2, 3.2, length.out = 200),
  y_top = 0.42 * sqrt(pmax(0, 10 - x^2)),
  y_bottom = -0.42 * sqrt(pmax(0, 10 - x^2))
)

# Crea plot interattivo con dropdown
initial_state <- "Luce intensa"
initial_data <- all_pupils |> filter(state == initial_state)

fig <- plot_ly() |>
  
  # Palpebra superiore
