    showlegend = FALSE,
    hoverinfo = "skip"
  ) |>
  
  # Palpebra inferiore
  add_trace(
    data = eyelid_data,
    x = ~x, y = ~y_bottom,
    type = "scatter", mode = "lines",
    line = list(color = "#0f2d52", width = 3),
    showlegend = FALSE,
    hoverinfo = "skip"
  )

# Aggiungi trace per ogni stato
for (state_name in names(states)) {
  state_data <- all_pupils |> filter(state == state_name)
  
  # Iride
  iris_data <- state_data |> filter(zone == "iride")
  fig <- fig |>
    add_trace(
      data = iris_data,
      x = ~x, y = ~y,
      type = "scatter", mode = "markers",
      marker = list(color = "#4ECDC4", size = 3, opacity = 0.4),
      visible = ifelse(state_name == initial_state, TRUE, FALSE),
      name = paste0(state_name, " - Iride"),
      showlegend = FALSE,
      hovertemplate = paste0(
        "<b>", state_name, "</b><br>",
        "Zona: Iride<br>",
        "Luminosità ambientale: ", unique(iris_data$light_pct), "%<br>",
        "Livello attenzione: ", unique(iris_data$attention_pct), "%<br>",
        "<extra></extra>"
      )
    )
  
  # Pupilla
  pupil_data <- state_data |> filter(zone == "pupilla")
  fig <- fig |>
    add_trace(
      data = pupil_data,
      x = ~x, y = ~y,
      type = "scatter", mode = "markers",
      marker = list(color = "#1a1a1a", size = 4, opacity = 0.85),
      visible = ifelse(state_name == initial_state, TRUE, FALSE),
      name = paste0(state_name, " - Pupilla"),
      showlegend = FALSE,
      hovertemplate = paste0(
        "<b>", state_name, "</b><br>",
        "Zona: Pupilla<br>",
        "Diametro: ", unique(pupil_data$pupil_diameter), " mm<br>",
        "Luminosità: ", unique(pupil_data$light_pct), "%<br>",
        "Attenzione: ", unique(pupil_data$attention_pct), "%<br>",
        "<extra></extra>"
      )
    )
}

# Crea menu dropdown
