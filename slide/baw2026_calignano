# ---------- Helpers ----------

rescale01 <- function(x) (x - min(x)) / (max(x) - min(x))

signal_data <- function(n = 500) {
  t <- seq(0, 10, length.out = n)
  true <- 0.15 * sin(1.6 * t) + 0.05 * cos(3.3 * t) +
    0.55 / (1 + exp(-(t - 4.3) * 3)) - 0.25 / (1 + exp(-(t - 7.8) * 6))
  noise <- rnorm(n, 0, 0.08)
  blink_idx <- sample(40:(n-40), 12)
  raw <- true + noise
  for (i in blink_idx) raw[(i-2):(i+2)] <- NA
  tibble(
    t = t,
    true = true,
    raw = raw
  ) |>
    mutate(
      interp = zoo::na.approx(raw, na.rm = FALSE),
      smooth = stats::filter(interp, rep(1/9, 9), sides = 2) |> as.numeric()
    )
}

brain_points <- function(n = 3000) {
  t <- runif(n, 0, 2*pi)
  # cuore deformato per ottenere una silhouette "brain-like"
  x <- 16 * sin(t)^3
  y <- 13*cos(t) - 5*cos(2*t) - 2*cos(3*t) - cos(4*t)

  x <- x / max(abs(x))
  y <- y / max(abs(y))

  left  <- tibble(x = -0.9 + 0.95*x + rnorm(n, 0, 0.02),
                  y = 0.95*y + rnorm(n, 0, 0.02),
                  lobe = sample(c("frontale", "parietale", "temporale", "occipitale"), n, TRUE))
  right <- tibble(x =  0.9 - 0.95*x + rnorm(n, 0, 0.02),
                  y = 0.95*y + rnorm(n, 0, 0.02),
                  lobe = sample(c("frontale", "parietale", "temporale", "occipitale"), n, TRUE))

  bind_rows(left, right) |>
    mutate(alpha = pmin(1, rescale01(-((x)^2 + (y)^2)) + runif(dplyr::n(), 0, 0.3)))
}

pupil_points <- function(n = 5000) {
  theta <- runif(n, 0, 2*pi)
  r1 <- sqrt(runif(n, 0, 1))
  iris <- tibble(
    x = 2.2 * r1 * cos(theta),
    y = 2.2 * r1 * sin(theta),
    zone = "iride"
  )

  theta2 <- runif(n/2, 0, 2*pi)
  r2 <- sqrt(runif(n/2, 0, 1))
  pupil <- tibble(
    x = 0.9 * r2 * cos(theta2),
    y = 0.9 * r2 * sin(theta2),
    zone = "pupilla"
  )

  eyelid <- tibble(
    x = seq(-3.2, 3.2, length.out = 400),
    y_top = 0.42 * sqrt(pmax(0, 10 - x^2)),
    y_bottom = -0.42 * sqrt(pmax(0, 10 - x^2))
  )

  list(points = bind_rows(iris, pupil), eyelid = eyelid)
}

aoi_points <- function(n = 1800) {
  tibble(
    x = c(rnorm(n*0.7, 0, 0.55), rnorm(n*0.3, 1.5, 0.8)),
    y = c(rnorm(n*0.7, 0, 0.55), rnorm(n*0.3, 0.2, 0.9)),
    inside = abs(c(rnorm(n*0.7, 0, 0.55), rnorm(n*0.3, 1.5, 0.8))) < 1 &
             abs(c(rnorm(n*0.7, 0, 0.55), rnorm(n*0.3, 0.2, 0.9))) < 1
  )
}

missing_matrix <- function(subjects = 18, timepoints = 100) {
  expand_grid(id = paste0("P", sprintf("%02d", 1:subjects)),
              t = 1:timepoints) |>
    group_by(id) |>
    mutate(
      base_p = runif(1, 0.05, 0.30),
      missing = rbinom(n(), 1, pmin(0.95, base_p + dnorm(t, 80, 12) * 1.8)) == 1
    ) |>
    ungroup()
}

baseline_data <- function() {
  t <- seq(0, 1000, by = 8)
  raw <- 3.2 + 0.03*sin(t/70) + ifelse(t > 250, 0.3*exp(-(t-500)^2/(2*180^2)), 0) + rnorm(length(t), 0, 0.02)
  b16 <- raw - median(raw[t <= 16])
  b100 <- raw - median(raw[t <= 100])
  b200 <- raw - median(raw[t <= 200])
  tibble(t = t, `Nessuna baseline` = raw, `Baseline 16 ms` = b16, `Baseline 100 ms` = b100, `Baseline 200 ms` = b200) |>
    pivot_longer(-t, names_to = "cond", values_to = "y")
}

multiverse_data <- function() {
  crossing(
    filtro = c("tutti i valori", "valori plausibili"),
    aoi = c("schermo intero", "solo AOI"),
    blink = c("escludi blink", "interpola blink"),
    baseline = c("16 ms", "100 ms", "200 ms")
  ) |>
    mutate(
      estimate = rnorm(n(), ifelse(filtro == "valori plausibili", -0.12, 0.03), 0.14) +
        ifelse(aoi == "solo AOI", -0.08, 0.04) +
        ifelse(blink == "interpola blink", 0.03, -0.02) +
        case_when(
          baseline == "16 ms" ~ 0.03,
          baseline == "100 ms" ~ 0.00,
          TRUE ~ -0.04
        ),
      low = estimate - runif(n(), 0.06, 0.18),
      high = estimate + runif(n(), 0.06, 0.18),
      robust = low > 0 | high < 0,
      model = row_number()
    )
}

