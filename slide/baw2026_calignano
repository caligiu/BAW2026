#| fig-width: 14
#| fig-height: 8

library(tidyverse)
library(plotly)
library(ggridges)
library(ggdist)
library(patchwork)
library(gt)

set.seed(123)

indiv_full <- crossing(
  id = paste0("S", sprintf("%02d", 1:18)),
  t = seq(0, 10, length.out = 250),
  cond = c("Visuale", "Audiovisiva")
) |>
  group_by(id, cond) |>
  mutate(
    individual_peak = rnorm(1, ifelse(first(cond) == "Visuale", 6.5, 5.5), 0.8),
    individual_amplitude = rnorm(1, ifelse(first(cond) == "Visuale", 0.35, 0.25), 0.08),
    phase_shift = runif(1, 0, 2 * pi),
    y = 0.12 * sin(1.5 * t + phase_shift) +
      individual_amplitude * exp(-(t - individual_peak)^2 / 2.5) +
      rnorm(n(), 0, 0.04)
  ) |>
  ungroup()

avg_summary <- indiv_full |>
  group_by(cond, id) |>
  summarise(mean_response = mean(y), .groups = "drop") |>
  group_by(cond) |>
  summarise(
    media = mean(mean_response),
    se = sd(mean_response) / sqrt(n()),
    .groups = "drop"
  )

indiv_means <- indiv_full |>
  group_by(cond, id) |>
  summarise(mean_response = mean(y), .groups = "drop")

dist_summary <- indiv_means |>
  group_by(cond) |>
  summarise(
    media = mean(mean_response),
