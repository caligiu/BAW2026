## Baseline: Da dove comincia il cambiamento?

Se misuro la variazione di attività per esempio rispetto a:

- 16 ms
- 100 ms
- 200 ms

dopo la comparsa dello stimolo, non sto facendo la stessa analisi.

::: {.fragment}
Anche il punto zero è una decisione teorica e statistica.
:::

## La baseline cambia la storia

```{r}
#| fig-width: 14
#| fig-height: 8

library(tidyverse)
library(plotly)

set.seed(123)

baseline_dramatic <- function() {
  t <- seq(-500, 2000, by = 4)

  trend <- 0.02 * (t + 500) / 1000
  response_onset <- ifelse(t > 0, 0.25 * exp(-(t - 150)^2 / (2 * 80^2)), 0)
  emotional_response <- ifelse(t > 200, 0.35 * exp(-(t - 500)^2 / (2 * 200^2)), 0)
  decay <- ifelse(t > 1200, -0.15 * (1 - exp(-(t - 1200) / 400)), 0)
  noise <- rnorm(length(t), 0, 0.03)

  raw <- 3.2 + trend + response_onset + emotional_response + decay + noise

  b_pre   <- raw - median(raw[t >= -200 & t <= 0])
  b_early <- raw - median(raw[t >= 0 & t <= 100])
  b_mid   <- raw - median(raw[t >= 100 & t <= 200])
  b_late  <- raw - median(raw[t >= 1500 & t <= 2000])

  tibble(
    t = t,
    `Nessuna correzione` = raw,
    `Baseline pre-stimolo (-200:0 ms)` = b_pre,
    `Baseline riconoscimento (0:100 ms)` = b_early,
    `Baseline pre-emozione (100:200 ms)` = b_mid,
    `Baseline abituazione (1500:2000 ms)` = b_late
  ) |>
    pivot_longer(-t, names_to = "condizione", values_to = "pupil_size")
}

base_drama <- baseline_dramatic()

g_drama <- ggplot(base_drama, aes(t, pupil_size, color = condizione, group = condizione)) +
  annotate("rect", xmin = -200, xmax = 0, ymin = -Inf, ymax = Inf,
           fill = "#e8f5e9", alpha = 0.3) +
  annotate("rect", xmin = 300, xmax = 800, ymin = -Inf, ymax = Inf,
           fill = "#fff3e0", alpha = 0.3) +
  geom_vline(xintercept = 0, linetype = "dashed", linewidth = 1.1, color = "#2c3e50", alpha = 0.6) +
  geom_hline(yintercept = 0, linetype = "dotted", linewidth = 0.9, color = "#7f8c8d", alpha = 0.5) +
  geom_line(linewidth = 1.25, alpha = 0.9) +
